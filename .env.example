# Copia este archivo como .env y completa las keys de los proveedores que quieras usar.
# Solo GROQ_API_KEY hace falta para el proveedor/modelo por defecto.
GROQ_API_KEY=tu_key_de_groq_aqui
CEREBRAS_API_KEY=tu_key_de_cerebras_aqui
OPENROUTER_API_KEY=tu_key_de_openrouter_aqui
MISTRAL_API_KEY=tu_key_de_mistral_aqui
GEMINI_API_KEY=tu_key_de_gemini_aqui
SPOTIFY_CLIENT_ID=tu_client_id_de_spotify_aqui
SPOTIFY_CLIENT_SECRET=tu_client_secret_de_spotify_aqui
